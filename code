#include <stdio.h>

struct Student {
    int roll;
    char name[50];
    int m1, m2, m3;
    int total;
    float percentage;
    char grade;
};

void calculate(struct Student *s) {
    s->total = s->m1 + s->m2 + s->m3;
    s->percentage = s->total / 3.0;

    if (s->percentage >= 90)
        s->grade = 'A';
    else if (s->percentage >= 75)
        s->grade = 'B';
    else if (s->percentage >= 60)
        s->grade = 'C';
    else if (s->percentage >= 40)
        s->grade = 'D';
    else
        s->grade = 'F';
}

int main() {
    struct Student s[50];
    int n = 0, choice;

    while (1) {
        printf("\n--- Student Grade Sheet Management ---\n");
        printf("1. Add Student\n");
        printf("2. Display Grade Sheet\n");
        printf("3. Exit\n");
        printf("Enter your choice: ");
        scanf("%d", &choice);

        switch (choice) {
        case 1:
            printf("\nEnter Roll Number: ");
            scanf("%d", &s[n].roll);

            printf("Enter Name: ");
            scanf(" %[^\n]", s[n].name);

            printf("Enter marks of 3 subjects:\n");
            scanf("%d%d%d", &s[n].m1, &s[n].m2, &s[n].m3);

            calculate(&s[n]);
            n++;
            printf("Student record added successfully!\n");
            break;

        case 2:
            if (n == 0) {
                printf("\nNo records found!\n");
            } else {
                printf("\nRoll\tName\tTotal\tPercent\tGrade\n");
                for (int i = 0; i < n; i++) {
                    printf("%d\t%s\t%d\t%.2f\t%c\n",
                           s[i].roll, s[i].name, s[i].total,
                           s[i].percentage, s[i].grade);
                }
            }
            break;

        case 3:
            printf("Exiting program...\n");
            return 0;

        default:
            printf("Invalid choice! Try again.\n");
        }
    }
}
