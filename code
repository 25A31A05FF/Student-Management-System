struct Student {
    int roll;
    char name[50];
    int m1, m2, m3;
    int total;
    float percentage;
    char grade;
};

void calculate(struct Student *s) {
    s->total = s->m1 + s->m2 + s->m3;
    s->percentage = s->total / 3.0;

    if (s->percentage >= 90)
        s->grade = 'A';
    else if (s->percentage >= 75)
        s->grade = 'B';
    else if (s->percentage >= 60)
        s->grade = 'C';
    else if (s->percentage >= 40)
        s->grade = 'D';
    else
        s->grade = 'F';
}

